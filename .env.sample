# SARSSA environment configuration — TEMPLATE
#
# Copy this file to `.env` in the repository root and fill in real
# values:
#
#     cp .env.sample .env
#
# `.env` is gitignored — never commit real credentials.

# OpenAI API key.
# Used by BOTH shipped providers:
#   - the OpenAI embedding provider  (src/utils/embedder)
#   - the OpenAI chat-LLM provider   (src/utils/llm)
# Required for any feature that uses an embedder or an LLM — today
# that means the labeling_evaluation embedding plugins. Without it
# those calls fail at request time.
OPENAI_API_KEY=sk-your-openai-api-key-here
